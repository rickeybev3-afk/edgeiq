modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "gce"
run = ["sh", "-c", "bash start.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Paper Trader Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Kalshi Prediction Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Batch Backtest (60 days)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nightly Tiered P&L Refresh"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "60-Day Backtest Runner"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "python-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Weekly Phase 3 Grid Search"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PM/IB Backfill"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Pending Sim Rows Backfill"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 deploy_server.py"
waitForPort = 8080

[[workflows.workflow]]
name = "Paper Trader Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python paper_trader_bot.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Kalshi Prediction Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python kalshi_bot.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Batch Backtest (60 days)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python backfill_close_prices.py && python run_sim_backfill.py"

[[workflows.workflow]]
name = "Nightly Tiered P&L Refresh"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python nightly_tiered_pnl_refresh.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "60-Day Backtest Runner"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 run_60day_backtest.py --start 2026-01-26 --end 2026-04-17"

[[workflows.workflow]]
name = "python-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest -v"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Weekly Phase 3 Grid Search"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 run_weekly_grid_search.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "PM/IB Backfill"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python backfill_pm_prevday_ib.py && echo 'Backfill complete — running filter grid search...' && python filter_grid_search.py"

[[workflows.workflow]]
name = "Pending Sim Rows Backfill"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python3 backfill_pending_sim_rows.py"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[userenv]

[userenv.shared]
LIVE_MIN_TCS = "70"
TZ = "America/New_York"
ADAPTIVE_POSITION_MGMT = "1"
EDGEIQ_PRODUCTION = "1"
PDT_MAX_DAY_TRADES = "999"
