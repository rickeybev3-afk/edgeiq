modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "gce"
run = ["sh", "-c", "bash start.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Paper Trader Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Kalshi Prediction Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Batch Backtest (60 days)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 8080"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Paper Trader Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python paper_trader_bot.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Kalshi Prediction Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python kalshi_bot.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Batch Backtest (60 days)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python batch_backtest.py --days 252 --scan-type all --user-id a5e1fcab-8369-42c4-8550-a8a19734510c"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[userenv]

[userenv.shared]
