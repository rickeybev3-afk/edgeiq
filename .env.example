# ============================================================
# EdgeIQ — environment variable reference
# Copy to .env and fill in the values that apply to your setup.
# Variables that have a default can be left unset; the server
# will fall back to the listed default automatically.
# ============================================================


# ------------------------------------------------------------
# Supabase (required for database access)
# ------------------------------------------------------------
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
VITE_SUPABASE_ANON_KEY=
SUPABASE_ACCESS_TOKEN=


# ------------------------------------------------------------
# Alpaca (required for live/paper trading and bar data)
# ------------------------------------------------------------
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Set to "true" to use the Alpaca paper-trading endpoint (default: true)
IS_PAPER_ALPACA=true

# How many times to retry a bar-data fetch before giving up (default: 2)
BACKFILL_BAR_FETCH_MAX_RETRIES=2


# ------------------------------------------------------------
# OpenAI (optional — enables AI-assisted journal features)
# ------------------------------------------------------------
OPENAI_API_KEY=


# ------------------------------------------------------------
# Telegram alerts (optional)
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_USERNAME=edgeiq_alerts_bot


# ------------------------------------------------------------
# Discord alerts (optional)
# ------------------------------------------------------------
DISCORD_WEBHOOK_URL=


# ------------------------------------------------------------
# Paper trader (optional)
# ------------------------------------------------------------
# Supabase user-id that owns paper-trade positions
PAPER_TRADE_USER_ID=


# ------------------------------------------------------------
# Notes passcode (optional)
# Protects the private notes section of the dashboard.
# Leave empty to disable the passcode gate.
# ------------------------------------------------------------
NOTES_PASSCODE=


# ------------------------------------------------------------
# TCS (Threshold Calibration Score) settings
# ------------------------------------------------------------

# Number of days of TCS history to retain in the threshold-history log.
# Entries older than this are pruned on each write. (default: 90 days)
TCS_HISTORY_RETENTION_DAYS=90

# Minimum TCS score a structure must reach to pass the calibration gate
# used in compute_structure_tcs_thresholds(). (default: 65)
# Relevant file: backend.py
TCS_BASE_SCORE=65


# ------------------------------------------------------------
# Log-rotation settings
# All *_MAX_BYTES values control the file size at which a log
# is rotated. All *_BACKUP_COUNT values control how many
# rolled-over copies are kept (e.g. foo.log.1, foo.log.2 …).
# Older backups beyond the count are deleted automatically.
# ------------------------------------------------------------

# Calibration-reset log  (calibrate_sp_mult.py)
#   If unset, the file is written next to calibrate_sp_mult.py in the project root.
#   Set to an absolute path to redirect to a mounted volume or centralised log dir.
#   Example: RESET_LOG_PATH=/var/log/edgeiq/calibration_resets.log
# RESET_LOG_PATH=
#   Units: bytes / count
RESET_LOG_MAX_BYTES=102400
RESET_LOG_BACKUP_COUNT=1

# TCS threshold-history log  (backend.py)
#   If unset, the file is written as tcs_threshold_history.jsonl relative to the
#   process working directory (typically the project root).
#   Set to an absolute path to redirect to a mounted volume or centralised log dir.
#   Example: TCS_HISTORY_LOG_PATH=/var/log/edgeiq/tcs_threshold_history.jsonl
# TCS_HISTORY_LOG_PATH=
#   Units: bytes / count
TCS_HISTORY_MAX_BYTES=512000
TCS_HISTORY_BACKUP_COUNT=1

# Backfill pipeline log  (app.py)
#   If unset, the file is written to /tmp/backfill_pipeline.log.
#   Set to an absolute path to redirect to a mounted volume or centralised log dir.
#   Example: BACKFILL_LOG_PATH=/var/log/edgeiq/backfill_pipeline.log
# BACKFILL_LOG_PATH=
#   Units: bytes / count
BACKFILL_LOG_MAX_BYTES=512000
BACKFILL_LOG_BACKUP_COUNT=1

# Backfill-run history log  (app.py)
#   If unset, the file is written next to app.py in the project root.
#   Set to an absolute path to redirect to a mounted volume or centralised log dir.
#   Example: BACKFILL_RUN_HISTORY_LOG_PATH=/var/log/edgeiq/backfill_run_history.log
# BACKFILL_RUN_HISTORY_LOG_PATH=
#   Units: bytes / count
BACKFILL_RUN_HISTORY_MAX_BYTES=102400
BACKFILL_RUN_HISTORY_BACKUP_COUNT=1


# ------------------------------------------------------------
# IB Context Enrichment  (paper_trader_bot.py)
# Off by default — enables an experimental ±0-5 TCS adjustment
# based on the prior day's IB range and the pre-market session
# range.  Turning this on adds ~0.3 s per ticker per scan and
# stores four extra nullable columns in paper_trades so you can
# compare results against the baseline system over time.
#
# Before enabling, run this once in Supabase → SQL Editor:
#
#   ALTER TABLE paper_trades
#     ADD COLUMN IF NOT EXISTS prev_ib_high      REAL,
#     ADD COLUMN IF NOT EXISTS prev_ib_low       REAL,
#     ADD COLUMN IF NOT EXISTS pm_range_pct      REAL,
#     ADD COLUMN IF NOT EXISTS ib_vs_prev_ib_pct REAL;
#
# ------------------------------------------------------------
# Set to 1 to enable, leave unset (or set to 0) to keep the
# current system completely unchanged.
IB_CONTEXT_ENABLED=0


# ------------------------------------------------------------
# Adaptive Position Management  (paper_trader_bot.py)
# Off by default — enables an 8:30 AM pre-open review of all
# open Alpaca paper positions.  For each directional position
# the bot fetches the current pre-market price and adjusts the
# bracket order using two rules:
#
#   Bullish Break, PM above IB high → raise TP by +0.5R
#   Bullish Break, PM inside IB     → tighten stop to IB mid
#   Bearish Break, PM below IB low  → lower TP by 0.5R
#   Bearish Break, PM inside IB     → tighten stop to IB mid
#
# Adjustments cancel the existing bracket legs and place a new
# OCO exit order.  Results are tagged in paper_trades so you can
# run an A/B comparison against the fixed-bracket baseline.
#
# Before enabling, run this once in Supabase → SQL Editor:
#
#   ALTER TABLE paper_trades
#     ADD COLUMN IF NOT EXISTS mgmt_mode     VARCHAR DEFAULT 'fixed',
#     ADD COLUMN IF NOT EXISTS tp_adjusted_r REAL;
#
# Set to 1 to enable, leave unset (or set to 0) to keep the
# current system completely unchanged.
ADAPTIVE_POSITION_MGMT=0
